# flexisip.conf — example configuration for the Flexisip SIP proxy (v2.6+).
# Copy to /etc/opt/belledonne-communications/flexisip/flexisip.conf and adjust.
#
# The ACME sidecar (lego) writes cert.pem + privkey.pem into
# /etc/flexisip/tls/ via the shared Docker volume.  The proxy auto-reloads
# certificates every 60 seconds (tls-certificates-check-interval=60).

[global]
# Public IP address clients connect to.
# IMPORTANT: replace with your server's public IP.
# host=<SIP_IP>

# Comma-separated list of public IP addresses the proxy should advertise in SIP/SDP.
# nat-addresses=<SIP_IP>

# Logging
log-level=info
user-agent=flexisip/2.6

# Runtime directory
runtime-dir=/var/run/flexisip

# TLS transport.  The sips: scheme is required for TLS (not transport=tls).
# Certificate and key paths are populated by the ACME sidecar container
# via the flexisip_certs Docker volume (mounted at /etc/flexisip/tls).
# The proxy auto-reloads every 60 seconds, so renewed certs take effect
# without a restart.
transports=sips:0.0.0.0:5061
tls-certificates-file=/etc/flexisip/tls/cert.pem
tls-certificates-private-key=/etc/flexisip/tls/privkey.pem
tls-certificates-check-interval=60

# ------------------------------------------------------------------
# Registrar: stores user bindings (AOR → contact)
# ------------------------------------------------------------------
[module::Registrar]
enabled=true
# Redis is the simplest backend for a single-proxy deployment.
# For multi-proxy deployments, point each proxy at the same Redis instance.
db-implementation=redis
redis-server-domain=127.0.0.1
redis-server-port=6379
# Optional authentication to Redis (uncomment if set)
# redis-auth-password=changeme
# redis-server-encryption=1
# redis-trusted-ca-certs=/etc/ssl/certs/ca-certificates.crt

# Contact registration parameters
reg-on-response=true
reg-on-register=true
max-contacts-per-registration=5
contact-parameters=enabled

# ------------------------------------------------------------------
# Authentication: digest auth for SIP users
# ------------------------------------------------------------------
[module::Authentication]
enabled=true
# Digest auth realm — set to your public SIP IP address.
auth-domain=<SIP_IP>
# Disable the "+" trick used to push a call to all devices of a user
# (re-enable for multi-device support).
disable-qop-auth=false
# Users are stored in a file-based backend.
# See https://wiki.linphone.org/xwiki/wiki/public/view/Flexisip/Configuration/Authentication/
db-implementation=file
file-path=/etc/flexisip/users.conf

# ------------------------------------------------------------------
# Presence: required by the conference server to discover participant devices
# ------------------------------------------------------------------
# [module::Presence]
# enabled=true

# ------------------------------------------------------------------
# Forward / routing
# ------------------------------------------------------------------
[module::Forward]
enabled=true
# Conference-factory URI must be routed to the local conference server.
# Conference focus URIs are dynamically created and routed automatically.
# route-to-voicemail=...

[module::Router]
# The conference factory URI: requests to <sip:conference-factory@<domain>>
# are forwarded to the conference server's transport.
# conference-factory-uri=sip:conference-factory@<SIP_IP>

# ------------------------------------------------------------------
# Media relays (Relay / DoS protection) — usually off for small deployments
# ------------------------------------------------------------------
# [module::MediaRelay]
# enabled=false

# ------------------------------------------------------------------
# DoS protection — disabled in Docker (iptables not available in containers).
# For production deployments, use external DoS protection (cloud firewall,
# fail2ban, etc.) instead of the in-container iptables-based module.
# ------------------------------------------------------------------
[module::DoSProtection]
enabled=false

# ------------------------------------------------------------------
# Firewall / port policy
# ------------------------------------------------------------------
# Internal: do not block 127.0.0.1 connections (the conference server runs
# on the same host and connects on localhost).
[FirewallPolicy]
# Allow the conference server to reach the proxy.
# (default policy is "decline" on production builds)
# internal-hosts=127.0.0.1
