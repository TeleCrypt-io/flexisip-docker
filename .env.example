# Environment for docker compose.
# Copy to .env and adjust before first run.

# --- End-to-end encryption (E2EE) — OPT-IN -------------------------------
# Set to "true" to enable true end-to-end encrypted conferences.
# Requires the EKT plugin (already installed in the conference image) and
# causes the conference entrypoint to switch the engine to SFU mode with
# ZRTP media encryption. Default is "false" (mixer mode, NOT E2EE).
ENABLE_EKT_SERVER=false

# --- Domain and TLS -----------------------------------------------------
# Your public DNS name for SIP.
SIP_DOMAIN=sip.example.com
# Directory containing agent.pem (cert) and agent.key (private key).
# Mounted read-only into the proxy container.
TLS_CERT_DIR=./certs

# --- Database ------------------------------------------------------------
# Rotate these placeholders before exposing anything publicly.
MARIADB_ROOT_PASSWORD=rootpw-CHANGEME
MARIADB_CONFERENCE_PASSWORD=confpw-CHANGEME

# --- TURN (coturn) -------------------------------------------------------
# Public IP of the host running coturn (for the external-ip directive).
TURN_PUBLIC_IP=203.0.113.10
TURN_REALM=sip.example.com
TURN_USER=turnuser
TURN_PASSWORD=turnpw-CHANGEME
