# Environment for docker compose.
# Copy to .env and adjust before first run.

# --- Public IP (required) ------------------------------------------------
# Your server's public IP address.  Used for:
#   - SIP TLS signaling (proxy listens on this IP)
#   - Let's Encrypt IP-certificate via HTTP-01 challenge (port 80 required)
SIP_IP=203.0.113.10

# --- TURN (coturn) — change from defaults ---------------------------------
# Public IP of the host running coturn (for the external-ip directive).
TURN_PUBLIC_IP=203.0.113.10
TURN_REALM=sip.example.com
TURN_USER=turnuser            # change to any non-trivial string
TURN_PASSWORD=change-me       # change to any non-trivial string

# --- E2EE (end-to-end encrypted conferences) ------------------------------
# E2EE (SFU engine + ZRTP) is ENABLED BY DEFAULT in config/flexisip-conference.conf
# ([conference-server] audio-engine-mode=sfu, video-engine-mode=sfu, encryption=zrtp).
# ENABLE_EKT_SERVER is retained ONLY as an intent/legacy signal — it no longer
# triggers any runtime config rewriting. Keep it "true" to document intent; the
# conference entrypoint logs it but E2EE comes from the config file.
# Verify E2EE is active by grepping the conference log for:
#   EKT server plugin for core sip:conference-focus@… has been succesfully loaded
ENABLE_EKT_SERVER=true
